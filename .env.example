# Xocial Platform - Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# =============================================================================
# AI KEY & CONFIGURATION
VERCEL_AI_GATEWAY_API_KEY=your_vercel_ai_gateway_api_key
VERCEL_AI_GATEWAY_URL=https://ai-gateway.vercel.sh
# =============================================================================
# SUPABASE CONFIGURATION
# Get these values from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (use with caution - server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# =============================================================================
# DATABASE CONFIGURATION (SUPABASE)
# Get these from: https://supabase.com/dashboard/project/_/settings/database
# =============================================================================

# Connection pooling URL (for serverless functions - Vercel/Netlify)
# Port 6543 with pgbouncer=true
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection URL (for migrations and direct queries)
# Port 5432 without pooling
DIRECT_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT Secret (generate using: openssl rand -hex 32)
JWT_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32

# Session Secret (generate using: openssl rand -hex 32)
SESSION_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32

# =============================================================================
# SOCIAL MEDIA API KEYS
# =============================================================================

# Facebook / Meta Login for Business
# Get from: https://developers.facebook.com
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
META_GRAPH_API_VERSION=v25.0
# Instagram API with Instagram Login
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# Optional Facebook Login for Business configuration IDs from:
# Facebook Login for Business -> Configurations.
# Use separate IDs only if you created separate login configurations.
FACEBOOK_LOGIN_CONFIG_ID=
# Backward-compatible fallback for the Instagram-via-Facebook Page configuration.
INSTAGRAM_LOGIN_CONFIG_ID=
INSTAGRAM_FACEBOOK_LOGIN_CONFIG_ID=
# Optional. Use this for Meta OAuth testing through an HTTPS tunnel or preview URL
# when Meta does not accept localhost for Business Login callbacks.
# Example: https://your-tunnel.ngrok-free.app
META_OAUTH_REDIRECT_ORIGIN=

# Twitter / X
# Get from: https://developer.twitter.com
TWITTER_CLIENT_ID=your_x_client_id
TWITTER_CLIENT_SECRET=your_x_client_secret

# LinkedIn
# Get from: https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_API_VERSION=202605

# Google / YouTube
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# YouTube (uses same Google credentials)
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret

# TikTok
# Get from: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Pinterest
# Get from: https://developers.pinterest.com
PINTEREST_CLIENT_ID=your_pinterest_app_id
PINTEREST_CLIENT_SECRET=your_pinterest_app_secret

# Bluesky / AT Protocol
# Prefer user-provided app passwords over account passwords.
BLUESKY_APP_PASSWORD_ENCRYPTION_SALT=replace_with_random_secret

# =============================================================================
# OPTIONAL: REDIS / UPSTASH (for caching and rate limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# OPTIONAL: ANALYTICS
# =============================================================================
NEXT_PUBLIC_GA_ID=your_google_analytics_id
# =============================================================================
ENCRYPTION_KEY=replace_with_64_hex_chars_from_openssl_rand_hex_32
# =============================================================================
CRON_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32
# =============================================================================

# =============================================================================
# Razorpay Billing
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# =============================================================================
# Razorpay Plan IDs (create these in Razorpay dashboard)
# =============================================================================
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_PRO_YEARLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_GROWTH_MONTHLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_GROWTH_YEARLY=plan_xxxxxxxxxxxxx

# NOTES
# =============================================================================
# 
# For Local Development:
# 1. Copy this file to .env.local
# 2. Fill in your Supabase credentials
# 3. Generate JWT_SECRET and SESSION_SECRET
# 4. Add social media API keys as needed
#
# For Vercel Deployment:
# 1. Go to: https://vercel.com/[team]/[project]/settings/environment-variables
# 2. Add all variables above
# 3. Select "Production", "Preview", and "Development" environments
# 4. Deploy!
#
# Security:
# - Never commit .env.local to Git
# - Rotate secrets regularly
# - Use different secrets for each environment
# - Keep service role keys server-side only
#
# Platform availability flags for frontend
NEXT_PUBLIC_YOUTUBE_ENABLED=true
NEXT_PUBLIC_FACEBOOK_ENABLED=true
NEXT_PUBLIC_TWITTER_ENABLED=true
SUPABASE_DB_PASSWORD=your_supabase_database_password
DEMO_PUBLISH=false

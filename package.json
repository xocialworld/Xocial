{
  "name": "xocial-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run check-env && next dev",
    "dev:skip-check": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 . --ext .js,.ts,.tsx",
    "lint:fix": "eslint --fix . --ext .js,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "check-env": "node scripts/check-env.js",
    "setup-env": "node scripts/setup-env.js",
    "db:seed": "tsx scripts/seed-database.ts",
    "db:migrate": "tsx scripts/apply-migration.ts",
    "scheduler:once": "tsx scripts/run-scheduler.ts",
    "scheduler:dev": "tsx scripts/run-scheduler.ts --watch --interval=60",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test:ci && npm run test:e2e",
    "analyze": "ANALYZE=true npm run build",
    "prepare": "node -e \"if (process.env.CI !== 'true' && process.env.VERCEL !== '1') { require('child_process').execSync('husky install', {stdio: 'inherit'}) }\"",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "ai": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.7",
    "import-in-the-middle": "^2.0.0",
    "lucide-react": "^0.446.0",
    "next": "14.2.15",
    "postcss": "^8",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.12.7",
    "require-in-the-middle": "^8.0.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.3",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "uuid": "^13.0.0",
    "web-vitals": "^3.5.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@mswjs/data": "^0.16.2",
    "@next/bundle-analyzer": "14.2.15",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.15.6",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.12.1",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6"
  }
}
